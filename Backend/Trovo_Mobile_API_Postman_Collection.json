{
	"info": {
		"_postman_id": "a9341400-d872-4d1a-b615-1888e2c21213",
		"name": "Trovo Mobile App API",
		"description": "API Collection for Trovo Mobile App — Email/Password + Google OAuth Authentication System.\nAuto-saves tokens from login/register responses.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Auth — Registration & Verification",
			"item": [
				{
					"name": "Register (Email + Password)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if(jsonData.access_token) {",
									"        pm.collectionVariables.set(\"auth_token\", jsonData.access_token);",
									"        console.log(\"Token auto-saved!\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "name", "value": "Ahmed Ali", "type": "text" },
								{ "key": "email", "value": "ahmed@example.com", "type": "text" },
								{ "key": "password", "value": "password123", "type": "text" },
								{ "key": "password_confirmation", "value": "password123", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/register",
							"host": ["{{base_url}}"],
							"path": ["register"]
						},
						"description": "Creates a new account and sends an OTP code to the email for verification.\n\nReturns: access_token (limited until email is verified)"
					},
					"response": []
				},
				{
					"name": "Verify Email (OTP)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "email", "value": "ahmed@example.com", "type": "text" },
								{ "key": "code", "value": "123456", "description": "6-digit OTP from email", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/verify-email",
							"host": ["{{base_url}}"],
							"path": ["verify-email"]
						},
						"description": "Verifies the email address using a 6-digit OTP code.\nAfter verification, the user gets full access to all features."
					},
					"response": []
				},
				{
					"name": "Resend OTP",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "email", "value": "ahmed@example.com", "type": "text" },
								{ "key": "type", "value": "email_verification", "description": "email_verification or password_reset", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/resend-otp",
							"host": ["{{base_url}}"],
							"path": ["resend-otp"]
						},
						"description": "Resends the OTP code. Max 5 per hour per email."
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Auth — Login",
			"item": [
				{
					"name": "Login (Email + Password)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if(jsonData.access_token) {",
									"        pm.collectionVariables.set(\"auth_token\", jsonData.access_token);",
									"        console.log(\"Token auto-saved!\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "email", "value": "ahmed@example.com", "type": "text" },
								{ "key": "password", "value": "password123", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Login with email and password. Email must be verified.\nIf not verified, returns 403 with status 'email_not_verified'."
					},
					"response": []
				},
				{
					"name": "Login with Google",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var code = pm.response.code;",
									"if (code === 200 || code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if(jsonData.access_token) {",
									"        pm.collectionVariables.set(\"auth_token\", jsonData.access_token);",
									"        console.log(\"Token auto-saved!\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "id_token", "value": "", "description": "Google ID token from mobile SDK", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/auth/google",
							"host": ["{{base_url}}"],
							"path": ["auth", "google"]
						},
						"description": "Sign in or register with Google account.\nSends the id_token from Google Sign-In SDK.\nAuto-creates account if new user, auto-verifies email."
					},
					"response": []
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/user",
							"host": ["{{base_url}}"],
							"path": ["user"]
						},
						"description": "Returns current user profile data.\nWorks even if email is not verified."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/logout",
							"host": ["{{base_url}}"],
							"path": ["logout"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Auth — Password Management",
			"item": [
				{
					"name": "Forgot Password (Send OTP)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "email", "value": "ahmed@example.com", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/forgot-password",
							"host": ["{{base_url}}"],
							"path": ["forgot-password"]
						},
						"description": "Sends a password reset OTP to the email.\nReturns same success message whether email exists or not (security)."
					},
					"response": []
				},
				{
					"name": "Reset Password (with OTP)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "email", "value": "ahmed@example.com", "type": "text" },
								{ "key": "code", "value": "123456", "description": "6-digit OTP from email", "type": "text" },
								{ "key": "password", "value": "newpassword123", "type": "text" },
								{ "key": "password_confirmation", "value": "newpassword123", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/reset-password",
							"host": ["{{base_url}}"],
							"path": ["reset-password"]
						},
						"description": "Resets the password using OTP + new password.\nAll existing tokens are revoked after reset."
					},
					"response": []
				},
				{
					"name": "Change Password (Logged In)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "current_password", "value": "password123", "type": "text" },
								{ "key": "password", "value": "newpassword123", "type": "text" },
								{ "key": "password_confirmation", "value": "newpassword123", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/user/change-password",
							"host": ["{{base_url}}"],
							"path": ["user", "change-password"]
						},
						"description": "Change password for logged-in user.\nRequires current password verification.\nGoogle-only users can set a password without current_password."
					},
					"response": []
				}
			]
		},
		{
			"name": "4. Account Management",
			"item": [
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "name", "value": "Ahmed Mohamed Ali", "type": "text" },
								{ "key": "avatar", "value": "https://example.com/avatar.jpg", "type": "text", "disabled": true }
							]
						},
						"url": {
							"raw": "{{base_url}}/user/update-profile",
							"host": ["{{base_url}}"],
							"path": ["user", "update-profile"]
						},
						"description": "Update profile name and/or avatar URL.\nRequires verified email."
					},
					"response": []
				},
				{
					"name": "Delete Account",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "password", "value": "password123", "description": "Required for password-based accounts", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/user/delete-account",
							"host": ["{{base_url}}"],
							"path": ["user", "delete-account"]
						},
						"description": "Permanently deletes the account and all associated data.\nRequires password confirmation (not needed for Google-only accounts)."
					},
					"response": []
				}
			]
		},
